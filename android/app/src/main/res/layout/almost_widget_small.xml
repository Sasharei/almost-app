<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@drawable/widget_bg"
  android:padding="7dp"
  android:paddingBottom="7dp">

  <LinearLayout
    android:id="@+id/widget_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
      android:id="@+id/widget_header"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="3dp">

      <ImageView
        android:id="@+id/widget_cat"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:padding="3dp"
        android:scaleType="centerInside"
        android:src="@drawable/almi_widget"
        android:background="@drawable/widget_cat_bg" />

      <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="6dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/widget_title_default"
        android:textColor="#111111"
        android:textSize="11sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/widget_metric_column"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:background="@drawable/widget_panel_hero"
      android:padding="6dp">

    <TextView
      android:id="@+id/widget_saved_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:autoSizeTextType="uniform"
      android:autoSizeMinTextSize="7sp"
      android:autoSizeMaxTextSize="10sp"
      android:ellipsize="end"
      android:includeFontPadding="false"
      android:maxLines="1"
      android:text="@string/widget_label_total_default"
      android:textColor="#4B4B4B"
      android:textSize="10sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_saved_value"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:autoSizeTextType="uniform"
      android:autoSizeMinTextSize="10sp"
      android:autoSizeMaxTextSize="20sp"
      android:ellipsize="end"
      android:includeFontPadding="false"
      android:maxLines="1"
      android:text="--"
      android:textColor="#2EB873"
      android:textSize="20sp"
      android:textStyle="bold" />

    <LinearLayout
      android:id="@+id/widget_progress_month_group"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:orientation="vertical">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/widget_progress_month_label"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:autoSizeTextType="uniform"
          android:autoSizeMinTextSize="7sp"
          android:autoSizeMaxTextSize="9sp"
          android:ellipsize="end"
          android:includeFontPadding="false"
          android:maxLines="1"
          android:text="@string/widget_label_month_goal_default"
          android:textColor="#4B4B4B"
          android:textSize="9sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_progress_month_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:includeFontPadding="false"
          android:maxLines="1"
          android:text="0%"
          android:textColor="#555555"
          android:textSize="9sp"
          android:textStyle="bold" />
      </LinearLayout>

      <ProgressBar
        android:id="@+id/widget_progress_month_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="1dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="#1A000000"
        android:progressTint="#2EB873"
        android:minHeight="4dp"
        android:maxHeight="4dp" />
    </LinearLayout>
    </LinearLayout>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:text="" />

    <LinearLayout
      android:id="@+id/widget_actions_row"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginTop="5dp"
      android:layout_marginBottom="0dp">

      <TextView
        android:id="@+id/widget_save_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/widget_action_save_default"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/widget_button_save_bg"
        android:minHeight="28dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

      <TextView
        android:layout_width="6dp"
        android:layout_height="1dp"
        android:text="" />

      <TextView
        android:id="@+id/widget_spend_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/widget_action_spend_default"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/widget_button_spend_bg"
        android:minHeight="28dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/widget_empty_state"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/widget_panel_hero"
    android:padding="12dp"
    android:visibility="gone">

  <ImageView
    android:id="@+id/widget_empty_cat"
    android:layout_width="38dp"
    android:layout_height="38dp"
    android:padding="5dp"
    android:scaleType="centerInside"
    android:src="@drawable/almi_widget"
    android:background="@drawable/widget_cat_bg" />

  <TextView
    android:id="@+id/widget_empty_state_label"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:gravity="center"
    android:maxLines="2"
    android:ellipsize="end"
    android:text="@string/widget_empty_state_default"
    android:textColor="#1C1C1C"
    android:textSize="12sp"
    android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
